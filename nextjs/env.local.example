# ===================================
# Next.js Environment Variables
# ===================================
# Скопируйте этот файл как .env.local и заполните значения

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://unident.ru
NEXT_PUBLIC_SITE_NAME=УниДент

# WordPress Configuration
NEXT_PUBLIC_WP_URL=http://localhost:8002
NEXT_PUBLIC_WORDPRESS_URL=http://localhost:8002

# Faust.js Configuration
FAUST_SECRET_KEY=your-secret-key-here

# GraphQL Endpoint
# Для npm run dev на хосте — localhost. Для Docker — host.docker.internal или IP.
# KAN (wp-kb): http://localhost:8010/graphql
# Unident (wp-new): http://localhost:8002/graphql
NEXT_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:8002/graphql

# ===================================
# SEO & Analytics
# ===================================

# Google Search Console Verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Yandex Webmaster Verification
NEXT_PUBLIC_YANDEX_VERIFICATION=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Yandex Metrika
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# Yandex Maps API 3 (секция «Клиники на карте»)
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# MapTiler (карта клиник — Leaflet): бесплатный ключ на cloud.maptiler.com
# Чтобы подписи на карте были по-русски на всех zoom: создайте копию карты Basic,
# Settings → Worldview → Language = Local, опубликуйте и укажите ID карты ниже
NEXT_PUBLIC_MAPTILER_API_KEY=
NEXT_PUBLIC_MAPTILER_MAP_ID=basic-v2

# Провайдер тайлов без MapTiler: osm (по умолчанию, стабилен в Узбекистане и др.) или carto
# NEXT_PUBLIC_MAP_TILE_PROVIDER=osm
# NEXT_PUBLIC_MAP_TILE_PROVIDER=carto

# ===================================
# Optional Services
# ===================================

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Development Mode
NODE_ENV=development

# ===================================
# Security
# ===================================

# JWT Secret для WordPress Auth
JWT_SECRET_KEY=your-jwt-secret-here

# ===================================
# Performance
# ===================================

# Enable Debug Mode
NEXT_PUBLIC_DEBUG=false

# Enable Analytics in Development
NEXT_PUBLIC_ANALYTICS_ENABLED=false
