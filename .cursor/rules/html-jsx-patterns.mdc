## 2️⃣ Component Structure

### Порядок элементов в файле

```typescript
// 1. Импорты
import { Card, Heading, Text } from '@/components/design-system';
import type { Doctor } from '@/types';

// 2. Основной экспортируемый компонент
export function DoctorCard({ doctor }: Props) {
  return (
    <Card>
      <DoctorHeader doctor={doctor} />
      <DoctorBody doctor={doctor} />
    </Card>
  );
}

// 3. Подкомпоненты
function DoctorHeader({ doctor }: Props) {
  return <Heading level={3}>{doctor.name}</Heading>;
}

function DoctorBody({ doctor }: Props) {
  return <Text variant="doctor-description">{doctor.specialty}</Text>;
}

// 4. Вспомогательные функции
function formatExperience(years: number): string {
  return `${years} лет опыта`;
}

// 5. TypeScript типы
interface Props {
  doctor: Doctor;
}
```

### Named exports

**✅ ПРАВИЛЬНО:**

```typescript
export function DoctorCard({ doctor }: Props) { ... }
export function DoctorList({ doctors }: Props) { ... }
```

**❌ ИЗБЕГАЙ default exports:**

```typescript
export default function DoctorCard({ doctor }: Props) { ... } // Плохо!
```

