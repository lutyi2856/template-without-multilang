## 9️⃣ Примеры правильных паттернов

### Пример 1: Карточка врача (полная)

```tsx
import { Card, Heading, Text, Badge, Button } from '@/components/design-system';
import Image from 'next/image';
import type { Doctor } from '@/types';

// Server Component
export async function DoctorCard({ doctorId }: Props) {
  const doctor = await fetchDoctor(doctorId);
  
  return (
    <Card variant="bordered">
      <article className="flex flex-col gap-4">
        <Image
          src={doctor.avatar}
          alt={`Фото врача ${doctor.name}`}
          width={300}
          height={300}
          className="rounded-[15px]"
        />
        
        <Heading level={3} variant="card-title">
          {doctor.name}
        </Heading>
        
        <Text variant="doctor-description">
          {doctor.specialty}
        </Text>
        
        <div className="flex gap-2">
          <Badge variant="experience">
            {doctor.experience} лет опыта
          </Badge>
          <Badge variant="rating">
            {doctor.rating} ★
          </Badge>
        </div>
        
        <BookingButton doctorId={doctor.id} /> {/* Client Component */}
      </article>
    </Card>
  );
}

// Client Component для интерактивности
'use client'
function BookingButton({ doctorId }: { doctorId: string }) {
  const [isOpen, setIsOpen] = useState(false);
  
  return (
    <Button unidentVariant="primary" onClick={() => setIsOpen(true)}>
      Записаться на прием
    </Button>
  );
}

interface Props {
  doctorId: string;
}
```

### Пример 2: Список с фильтрацией

```tsx
// Server Component
async function DoctorsPage({ searchParams }: Props) {
  const doctors = await fetchDoctors({
    specialty: searchParams.specialty,
    page: searchParams.page || 1
  });
  
  return (
    <main>
      <Heading level={1} variant="page-title">Наши врачи</Heading>
      
      <SpecialtyFilter /> {/* Client Component */}
      
      <section className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {doctors.map(doctor => (
          <DoctorCard key={doctor.id} doctorId={doctor.id} />
        ))}
      </section>
      
      <Pagination pageInfo={doctors.pageInfo} />
    </main>
  );
}
```

