## 6️⃣ Error Handling

### Graceful degradation

**✅ ПРАВИЛЬНО:**

```tsx
'use client'
function DoctorsList() {
  const { data, loading, error, refetch } = useQuery(GET_DOCTORS);
  
  // Loading state
  if (loading) {
    return (
      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        {Array.from({ length: 6 }).map((_, i) => (
          <Skeleton key={i} className="h-[400px]" />
        ))}
      </div>
    );
  }
  
  // Error state
  if (error) {
    return (
      <div className="text-center py-12">
        <Text variant="large" className="text-red-600 mb-4">
          Не удалось загрузить список врачей
        </Text>
        <Button onClick={() => refetch()} unidentVariant="outline">
          Попробовать снова
        </Button>
      </div>
    );
  }
  
  // Empty state
  if (!data?.doctors?.edges?.length) {
    return (
      <Text variant="large">Врачи не найдены</Text>
    );
  }
  
  // Success state
  return (
    <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
      {data.doctors.edges.map(({ node: doctor }) => (
        <DoctorCard key={doctor.id} doctor={doctor} />
      ))}
    </div>
  );
}
```

