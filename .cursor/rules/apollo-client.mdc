## 2️⃣ Query Patterns

### Server Components (предпочтительно)

**✅ ПРАВИЛЬНО - fetch в Server Component:**

```typescript
// app/doctors/page.tsx
import { getClient } from '@/lib/apollo-client';
import { gql } from '@apollo/client';

const GET_DOCTORS = gql`
  query GetDoctors($first: Int = 50) {
    doctors(first: $first) {
      edges {
        node {
          id
          title
          doctorFields {
            specialty
            experience
            rating
            avatar {
              sourceUrl
              mediaDetails { width height }
            }
          }
        }
      }
    }
  }
`;

export default async function DoctorsPage() {
  const { data } = await getClient().query({
    query: GET_DOCTORS,
    variables: { first: 50 },
    context: {
      fetchOptions: {
        next: { revalidate: 3600 }, // ISR 1 hour
      },
    },
  });
  
  return (
    <main>
      {data.doctors.edges.map(({ node: doctor }) => (
        <DoctorCard key={doctor.id} doctor={doctor} />
      ))}
    </main>
  );
}
```

### Client Components (когда нужна интерактивность)

**✅ ПРАВИЛЬНО - useQuery в Client Component:**

```tsx
'use client'
import { useQuery, gql } from '@apollo/client';
import { Suspense } from 'react';

const GET_DOCTOR = gql`
  query GetDoctor($id: ID!) {
    doctor(id: $id) {
      id
      title
      doctorFields {
        specialty
        bio
      }
    }
  }
`;

function DoctorDetail({ doctorId }: Props) {
  const { data, loading, error } = useQuery(GET_DOCTOR, {
    variables: { id: doctorId },
    fetchPolicy: 'cache-first', // Используй кэш
  });
  
  if (loading) return <Skeleton />;
  if (error) return <ErrorMessage error={error} />;
  
  return <DoctorProfile doctor={data.doctor} />;
}

// Обернуть в Suspense
export function DoctorDetailWrapped(props: Props) {
  return (
    <Suspense fallback={<Skeleton />}>
      <DoctorDetail {...props} />
    </Suspense>
  );
}
```

