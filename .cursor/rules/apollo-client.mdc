## 4️⃣ Mutations

### useMutation pattern

**✅ ПРАВИЛЬНО:**

```tsx
'use client'
import { useMutation, gql } from '@apollo/client';

const CREATE_APPOINTMENT = gql`
  mutation CreateAppointment($input: CreateAppointmentInput!) {
    createAppointment(input: $input) {
      appointment {
        id
        date
        time
        doctor {
          id
          title
        }
      }
    }
  }
`;

function BookingForm({ doctorId }: Props) {
  const [createAppointment, { data, loading, error }] = useMutation(
    CREATE_APPOINTMENT,
    {
      // Обновить кэш после мутации
      update(cache, { data }) {
        cache.modify({
          fields: {
            appointments(existing = []) {
              return [...existing, data.createAppointment.appointment];
            },
          },
        });
      },
      // Или refetch queries
      refetchQueries: ['GetAppointments'],
    }
  );
  
  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    
    try {
      await createAppointment({
        variables: {
          input: { doctorId, date, time }
        }
      });
      
      toast.success('Запись создана!');
    } catch (err) {
      toast.error('Ошибка записи');
    }
  };
  
  return (
    <form onSubmit={handleSubmit}>
      {/* Форма */}
      <Button type="submit" disabled={loading}>
        {loading ? 'Записываем...' : 'Записаться'}
      </Button>
    </form>
  );
}
```

