## 3️⃣ ARIA Attributes

### ARIA labels для описания элементов

**✅ ПРАВИЛЬНО:**

```tsx
// Кнопка закрытия
<button 
  onClick={onClose}
  aria-label="Закрыть модальное окно"
>
  <XIcon /> {/* Иконка без текста */}
</button>

// Кнопка с иконкой
<button aria-label="Позвонить в клинику">
  <PhoneIcon />
  +7 900 123-45-67
</button>

// Навигация
<nav aria-label="Основная навигация сайта">
  <ul>
    <li><a href="/services" aria-current="page">Услуги</a></li>
  </ul>
</nav>

// Search
<form role="search" aria-label="Поиск врачей">
  <input 
    type="search"
    aria-label="Введите имя врача или специальность"
  />
</form>
```

### ARIA live regions для динамических изменений

**✅ ПРАВИЛЬНО - уведомления для screen readers:**

```tsx
'use client'
function BookingForm() {
  const [status, setStatus] = useState('');
  
  return (
    <form onSubmit={handleSubmit}>
      <input type="text" aria-label="Ваше имя" />
      
      {/* Screen reader объявит изменения */}
      <div 
        role="status" 
        aria-live="polite"
        aria-atomic="true"
      >
        {status}
      </div>
      
      <button type="submit">Записаться</button>
    </form>
  );
}
```

### ARIA для сложных компонентов

**Modal dialog:**

```tsx
'use client'
function AppointmentModal({ isOpen, onClose }: Props) {
  return (
    <Dialog open={isOpen} onOpenChange={onClose}>
      <DialogContent
        role="dialog"
        aria-modal="true"
        aria-labelledby="modal-title"
        aria-describedby="modal-description"
      >
        <DialogTitle id="modal-title">
          Запись на прием
        </DialogTitle>
        <DialogDescription id="modal-description">
          Заполните форму для записи
        </DialogDescription>
        
        <button 
          onClick={onClose}
          aria-label="Закрыть модальное окно"
        >
          ×
        </button>
      </DialogContent>
    </Dialog>
  );
}
```

**Accordion:**

```tsx
<div>
  <button
    onClick={toggle}
    aria-expanded={isExpanded}
    aria-controls="content-1"
  >
    Подробнее о враче
  </button>
  
  <div 
    id="content-1"
    role="region"
    hidden={!isExpanded}
  >
    {content}
  </div>
</div>
```

