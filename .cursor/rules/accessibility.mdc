## 🎓 Примеры правильных компонентов

### Doctor Card (полный a11y)

```tsx
async function DoctorCard({ doctorId }: Props) {
  const doctor = await fetchDoctor(doctorId);
  
  return (
    <Card variant="bordered">
      <article aria-labelledby={`doctor-${doctor.id}`}>
        <Image
          src={doctor.avatar}
          alt={`Фотография врача ${doctor.name}`}
          width={300}
          height={300}
        />
        
        <Heading level={3} id={`doctor-${doctor.id}`}>
          {doctor.name}
        </Heading>
        
        <Text variant="doctor-description">
          {doctor.specialty}
        </Text>
        
        <div className="flex gap-2" role="list">
          <Badge variant="experience" role="listitem">
            <span className="sr-only">Стаж работы:</span>
            {doctor.experience} лет
          </Badge>
          
          <Badge variant="rating" role="listitem">
            <span className="sr-only">Рейтинг:</span>
            {doctor.rating} <StarIcon aria-hidden="true" />
          </Badge>
        </div>
        
        <Button 
          unidentVariant="primary"
          aria-label={`Записаться на прием к ${doctor.name}`}
        >
          Записаться
        </Button>
      </article>
    </Card>
  );
}
```

