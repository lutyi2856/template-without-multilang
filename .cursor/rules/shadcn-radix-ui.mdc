## 🔟 Performance

### Dynamic imports для модалов

**✅ ПРАВИЛЬНО - lazy load dialogs:**

```tsx
import dynamic from 'next/dynamic';

const AppointmentDialog = dynamic(
  () => import('@/components/appointment-dialog'),
  {
    loading: () => <Skeleton className="w-full h-[400px]" />,
    ssr: false // Dialog не нужен для SSR
  }
);

function DoctorPage() {
  const [showDialog, setShowDialog] = useState(false);
  
  return (
    <>
      <Button onClick={() => setShowDialog(true)}>Записаться</Button>
      {showDialog && <AppointmentDialog />}
    </>
  );
}
```

