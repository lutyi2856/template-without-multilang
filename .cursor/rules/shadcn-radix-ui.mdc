## 8️⃣ Примеры интеграции

### Appointment Booking Flow

```tsx
// components/appointment-booking.tsx
'use client'
import { Dialog, DialogContent, DialogTitle } from '@/components/ui/dialog';
import { Select, SelectContent, SelectItem } from '@/components/ui/select';
import { Button } from '@/components/design-system';

export function AppointmentBooking({ doctor, open, onOpenChange }: Props) {
  const [date, setDate] = useState('');
  const [time, setTime] = useState('');
  
  return (
    <Dialog open={open} onOpenChange={onOpenChange}>
      <DialogContent className="sm:max-w-md">
        <DialogTitle>Запись к {doctor.name}</DialogTitle>
        
        <form onSubmit={handleSubmit} className="space-y-4">
          <div>
            <label htmlFor="date">Дата приема</label>
            <Select value={date} onValueChange={setDate}>
              <SelectTrigger id="date">
                <SelectValue placeholder="Выберите дату" />
              </SelectTrigger>
              <SelectContent>
                <SelectItem value="2026-02-06">6 февраля</SelectItem>
                <SelectItem value="2026-02-07">7 февраля</SelectItem>
              </SelectContent>
            </Select>
          </div>
          
          <div>
            <label htmlFor="time">Время</label>
            <Select value={time} onValueChange={setTime}>
              <SelectTrigger id="time">
                <SelectValue placeholder="Выберите время" />
              </SelectTrigger>
              <SelectContent>
                <SelectItem value="10:00">10:00</SelectItem>
                <SelectItem value="11:00">11:00</SelectItem>
              </SelectContent>
            </Select>
          </div>
          
          <div className="flex gap-2 justify-end">
            <Button 
              type="button" 
              unidentVariant="outline"
              onClick={() => onOpenChange(false)}
            >
              Отменить
            </Button>
            <Button type="submit" unidentVariant="primary">
              Записаться
            </Button>
          </div>
        </form>
      </DialogContent>
    </Dialog>
  );
}
```

