## 6️⃣ Server Components & Client Components

### Radix компоненты требуют 'use client'

**✅ ПРАВИЛЬНО - выносить в отдельные Client Components:**

```tsx
// components/appointment-dialog.tsx
'use client'
import { Dialog, DialogContent } from '@/components/ui/dialog';

export function AppointmentDialog({ doctor, ...props }: Props) {
  return (
    <Dialog {...props}>
      <DialogContent>
        {/* Форма записи */}
      </DialogContent>
    </Dialog>
  );
}

// app/doctors/[id]/page.tsx
// Server Component
async function DoctorPage({ params }: Props) {
  const doctor = await fetchDoctor(params.id);
  
  return (
    <main>
      <Heading level={1}>{doctor.name}</Heading>
      <AppointmentDialog doctor={doctor} /> {/* Client Component */}
    </main>
  );
}
```

