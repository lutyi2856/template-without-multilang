## 4️⃣ Кастомизация стилей

### Через className (Tailwind)

**✅ ПРАВИЛЬНО:**

```tsx
import { Button } from '@/components/ui/button';

<Button 
  className="bg-unident-primary hover:bg-unident-primaryLight rounded-[15px]"
>
  Записаться
</Button>
```

### Через CVA (Class Variance Authority)

**Для создания вариантов в design-system:**

```typescript
// components/design-system/button.tsx
import { cva, type VariantProps } from 'class-variance-authority';
import { Button as ShadcnButton } from '@/components/ui/button';

const buttonVariants = cva(
  'rounded-[15px] font-semibold transition-colors', // base
  {
    variants: {
      unidentVariant: {
        primary: 'bg-unident-primary hover:bg-unident-primaryLight text-white',
        outline: 'border-2 border-unident-primary text-unident-primary hover:bg-unident-bgLightBlue',
        ghost: 'hover:bg-unident-bgElements text-unident-dark',
      },
      size: {
        default: 'px-6 py-3',
        sm: 'px-4 py-2',
        lg: 'px-8 py-4',
      }
    },
    defaultVariants: {
      unidentVariant: 'primary',
      size: 'default'
    }
  }
);

export function Button({ unidentVariant, size, className, ...props }: Props) {
  return (
    <ShadcnButton
      className={cn(buttonVariants({ unidentVariant, size }), className)}
      {...props}
    />
  );
}
```

