## 🎓 Примеры из практики

### Пример 1: Doctor Card Component

**❌ ПЛОХО - Client Component с fetch:**

```typescript
'use client'
function DoctorCard({ id }: Props) {
  const [doctor, setDoctor] = useState(null);
  
  useEffect(() => {
    fetch(`/api/doctors/${id}`)
      .then(res => res.json())
      .then(setDoctor);
  }, [id]);
  
  if (!doctor) return <Spinner />;
  
  return (
    <div>
      <img src={doctor.avatar} /> {/* CLS! */}
      <h2>{doctor.name}</h2>
    </div>
  );
}
```

**✅ ХОРОШО - Server Component:**

```typescript
// Server Component
async function DoctorCard({ id }: Props) {
  const doctor = await fetchDoctor(id); // На сервере, с кэшем
  
  return (
    <div>
      <Image
        src={doctor.avatar}
        alt={doctor.name}
        width={300}
        height={300}
        loading="lazy"
      />
      <h2>{doctor.name}</h2>
      <BookingButton doctorId={id} /> {/* Маленький Client Component */}
    </div>
  );
}

// Маленький Client Component для интерактивности
'use client'
function BookingButton({ doctorId }: Props) {
  const [isOpen, setIsOpen] = useState(false);
  return <button onClick={() => setIsOpen(true)}>Записаться</button>;
}
```

### Пример 2: Services List with Pagination

**❌ ПЛОХО - Весь список сразу:**

```typescript
async function ServicesPage() {
  const services = await fetchAllServices(); // 500+ услуг!
  
  return (
    <div>
      {services.map(service => (
        <ServiceCard key={service.id} service={service} />
      ))}
    </div>
  );
}
```

**✅ ХОРОШО - Pagination + ISR:**

```typescript
export const revalidate = 3600; // ISR 1 hour

async function ServicesPage({ searchParams }: Props) {
  const page = searchParams.page || 1;
  const { services, pageInfo } = await fetchServices({
    first: 50, // 50 услуг за раз
    after: getCursor(page)
  });
  
  return (
    <div>
      {services.map(service => (
        <ServiceCard key={service.id} service={service} />
      ))}
      <Pagination pageInfo={pageInfo} />
    </div>
  );
}
```

### Пример 3: GraphQL Query Optimization

**❌ ПЛОХО - Избыточный запрос:**

```graphql
query GetDoctors {
  doctors {
    id
    databaseId
    title
    content
    excerpt
    slug
    uri
    date
    modified
    author {
      node {
        name
        email
        avatar
        description
      }
    }
    featuredImage {
      node {
        sourceUrl
        altText
        title
        caption
        description
        mediaDetails {
          width
          height
          file
          sizes {
            name
            width
            height
            sourceUrl
          }
        }
      }
    }
    # ... еще 30 полей
  }
}
```

**✅ ХОРОШО - Только нужные поля:**

```graphql
query GetDoctors {
  doctors(first: 50) {
    edges {
      node {
        id
        title
        specialty
        experience
        featuredImage {
          node {
            sourceUrl(size: MEDIUM)
            mediaDetails {
              width
              height
            }
          }
        }
      }
    }
  }
}
```

