## ✅ DO: Правильные паттерны

### 1. Создание нового компонента

```tsx
// ✅ ПРАВИЛЬНО - используй Design System
import { Card, Heading, Text, Button } from '@/components/design-system';

export function DoctorCard({ name, description }: Props) {
  return (
    <Card variant="bordered">
      <Heading level={3} variant="card-title">
        {name}
      </Heading>
      <Text variant="doctor-description">
        {description}
      </Text>
      <Button unidentVariant="primary">
        Записаться
      </Button>
    </Card>
  );
}
```

### 2. Семантические варианты

```tsx
// ✅ ПРАВИЛЬНО - используй семантические имена
<Text variant="doctor-description">{description}</Text>
<Text variant="clinic-name" as="span">{clinic}</Text>
<Heading level={3} variant="card-title">{title}</Heading>
```

### 3. Правильный HTML тег через `as`

```tsx
// ✅ ПРАВИЛЬНО - укажи правильный тег
<Text variant="clinic-name" as="span">Клиника</Text>
<Text variant="label" as="label">Имя</Text>
```

### 4. Preset компоненты для стандартных элементов

```tsx
// ✅ ПРАВИЛЬНО - используй preset компоненты
<Button unidentVariant="primary">Записаться</Button>
<Card variant="bordered">Содержимое</Card>
<Badge variant="rating">4.7 ★</Badge>
```

### 5. Добавление новых токенов при необходимости

```typescript
// ✅ ПРАВИЛЬНО - добавь в design-tokens/typography.ts
figma: {
  'service-title': 'text-[20px] font-medium leading-[1.2]',
}

// Затем используй
<Text variant="service-title">Услуга</Text>
```

