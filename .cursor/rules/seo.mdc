## 4️⃣ robots.txt

**✅ ПРАВИЛЬНО:**

```typescript
// app/robots.ts
import { MetadataRoute } from 'next';

export default function robots(): MetadataRoute.Robots {
  return {
    rules: [
      {
        userAgent: '*',
        allow: '/',
        disallow: [
          '/api/',
          '/admin/',
          '/_next/',
          '/private/',
        ],
      },
      {
        userAgent: 'Googlebot',
        allow: '/',
        crawlDelay: 0,
      },
      {
        userAgent: 'Yandex',
        allow: '/',
        crawlDelay: 0,
      },
    ],
    sitemap: 'https://unident.ru/sitemap.xml',
    host: 'https://unident.ru',
  };
}
```

