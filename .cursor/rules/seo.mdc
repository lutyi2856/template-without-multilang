### Doctor (Person) schema

**✅ ПРАВИЛЬНО:**

```tsx
// app/doctors/[slug]/page.tsx
function DoctorStructuredData({ doctor }: Props) {
  const schema = {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': `https://unident.ru/doctors/${doctor.slug}#person`,
    
    name: doctor.name,
    image: doctor.avatar,
    jobTitle: doctor.specialty,
    
    worksFor: {
      '@type': 'Dentist',
      name: 'УниДент',
      url: 'https://unident.ru',
    },
    
    description: doctor.bio,
    
    alumniOf: doctor.education,
    
    ...(doctor.rating && {
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: doctor.rating.toString(),
        bestRating: '5',
        worstRating: '1',
      }
    }),
  };
  
  return (
    <script
      type="application/ld+json"
      dangerouslySetInnerHTML={{ __html: JSON.stringify(schema) }}
    />
  );
}
```

