## 3️⃣ Sitemap

### Dynamic sitemap

**✅ ПРАВИЛЬНО:**

```typescript
// app/sitemap.ts
import { MetadataRoute } from 'next';

export default async function sitemap(): Promise<MetadataRoute.Sitemap> {
  const baseUrl = 'https://unident.ru';
  
  // Статичные страницы
  const staticPages = [
    {
      url: baseUrl,
      lastModified: new Date(),
      changeFrequency: 'daily' as const,
      priority: 1,
    },
    {
      url: `${baseUrl}/services`,
      lastModified: new Date(),
      changeFrequency: 'weekly' as const,
      priority: 0.9,
    },
  ];
  
  // Динамические страницы врачей
  const doctors = await fetchAllDoctors();
  const doctorPages = doctors.map(doctor => ({
    url: `${baseUrl}/doctors/${doctor.slug}`,
    lastModified: new Date(doctor.modified),
    changeFrequency: 'monthly' as const,
    priority: 0.8,
  }));
  
  // Динамические страницы услуг
  const services = await fetchAllServices();
  const servicePages = services.map(service => ({
    url: `${baseUrl}/services/${service.slug}`,
    lastModified: new Date(service.modified),
    changeFrequency: 'monthly' as const,
    priority: 0.7,
  }));
  
  return [...staticPages, ...doctorPages, ...servicePages];
}
```

